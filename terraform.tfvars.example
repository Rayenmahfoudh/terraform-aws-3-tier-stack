# Copy this file to terraform.tfvars and fill in real values for AWS deployment
# For local dev with LocalStack, defaults in variables.tf work as-is.

is_local        = false
region          = "us-east-1"
project_name    = "patientping"
instance_type   = "t3.micro"
db_username     = "postgres"
db_password     = "your-strong-password-here"
ssh_public_key_path = "~/.ssh/patientping-key.pub"
